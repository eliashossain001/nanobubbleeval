# Internal Overleaf upload zips (regenerable, not source of truth)
paper_for_overleaf.zip

# dataset_release/ is tracked: it is the small-artifact bundle the
# anonymous mirror serves to reviewers (gold-hard tier + baseline predictions
# + Croissant metadata + schema spec; ~500 KB total, no annotator identity).
# Larger-than-GitHub artifacts (warehouse, full-text corpus when added) go
# to HuggingFace only and are NOT staged here.

# HF token cache (never commit credentials)
.cache/huggingface/

# Large warehouse data (regenerable from scripts/legacy_harvest/)
data/raw/master_inventory.csv

# Notebooks
.ipynb_checkpoints/

# Scratch / IDE-opened working files
debugging.py
scratch.py
sandbox/

# Harvest cache (regenerable via scripts/legacy_harvest/)
data/harvest_cache/

# Environment
.env
.env.local
*.local

# Internal / local-only docs (not for public repo)
