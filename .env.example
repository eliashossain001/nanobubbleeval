# NanoBubbleEval — environment variable template.
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
# Usage:
#   cp .env.example .env
#   # edit .env, then either:
#   #   - export the vars in your shell, or
#   #   - install python-dotenv and call load_dotenv() in your scripts.

# -- HuggingFace -----------------------------------------------------------
# Required for: B2 (PubMedBERT QA-span) model download, and B3 (Qwen2.5-7B-
# Instruct) inference via the HuggingFace Inference API or Transformers
# pipeline.
# Generate at: https://huggingface.co/settings/tokens
HF_TOKEN=

# Optional: pin a specific HF cache directory. Defaults to ~/.cache/huggingface
# HF_HOME=

# -- Optional baselines (not used in v1.0) ---------------------------------
# Reserved for v1.1 frontier-model ceilings. Leave blank for v1.0 runs.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# -- Logging ---------------------------------------------------------------
# Python logging level for the `nanoeval` CLI and library. One of:
# DEBUG | INFO | WARNING | ERROR | CRITICAL
NANOEVAL_LOG_LEVEL=INFO
